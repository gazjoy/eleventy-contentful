---
title: Events
layout: layouts/base.njk
permalink: /events/index.html
---

<h1>{{ title }}</h1>

<h2>Upcoming Events</h2>

{% for event in events.upcoming %}

	<div style="display:flex;">
		{% include "components/event-date-badge.njk" %}

		<div>
			{% if loop.first %}
				<p><em>Next Event!</em></p>
			{% endif %}
			
			<h3>{{ event.title }}</h3>

			<p><strong>{{ event.startDate | readableDate(event.endDate) }}</strong> {{event.startTime | readableTime}}</p>
			<p>{{ event.venue.name }}</p>

			{% if event.website %}
				<p><a href="{{ event.website }}" target="_blank" rel="noopener noreferrer">Event details (opens in a new tab)</a></p>
			{% endif %}
			
			{{ event.descriptionRichText | renderRichTextAsHtml | safe }}
		</div>
	</div>

{% endfor %}

<h2>Past Events</h2>

<div id="past-events-by-year">
	<div style="display:flex; gap:0.5rem;">
		{% for year, pastEvents in events.past %}
			<button type="button" data-year-tab="{{ year }}" style="padding:0.5rem 1rem; border:1px solid #222; border-radius:999px; background:#fff; min-width:5rem;">{{ year }}</button>
		{% endfor %}
	</div>

	{% for year, pastEvents in events.past %}
		<div data-year-panel="{{ year }}" style="display:none;">
			{% for event in pastEvents %}

				<div style="display:flex; gap:1.5rem; align-items:flex-start; margin:0 0 2.5rem;">
					{% include "components/event-date-badge.njk" %}

					<div>
						<h3>{{ event.title }}</h3>
						<p><strong>{{ event.startDate | readableDate(event.endDate) }}</strong> {{ event.startTime | readableTime }}</p>
						{% if event.venue %}
							<p>{{ event.venue.name }}</p>
						{% endif %}
					</div>
				</div>

			{% endfor %}
		</div>
	{% endfor %}
</div>

<script>
	(function () {
		const container = document.getElementById("past-events-by-year");

		const yearButtons = Array.from(container.querySelectorAll("[data-year-tab]"));
		const yearPanels = Array.from(container.querySelectorAll("[data-year-panel]"));

		if (!yearButtons.length || !yearPanels.length) return;

		let activeIndex = 0;

		const render = () => {
			yearButtons.forEach((button, index) => {
				const isActive = index === activeIndex;
				button.style.background = isActive ? "#666" : "#fff";
				button.style.color = isActive ? "#fff" : "#111";
				button.setAttribute("aria-pressed", isActive ? "true" : "false");
				button.style.cursor = "pointer";
			});

			yearPanels.forEach((panel, index) => {
				panel.style.display = index === activeIndex ? "block" : "none";
			});
		};

		yearButtons.forEach((button, index) => {
			button.addEventListener("click", () => {
				activeIndex = index;
				render();
			});
		});

		render();
	})();
</script>