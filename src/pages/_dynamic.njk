---
layout: layouts/base.njk
eleventyComputed:
  title: "{{ page.title }}"
pagination:
  data: pages.flatList
  size: 1
  alias: page
permalink: /{{ page.urlPath }}/index.html
---

<article>
  <h1>{{ page.title }}</h1>
  <div>{{ page.bodyRichText | renderRichTextAsHtml | safe }}</div>

  {% if page.childPages.length > 0 %}
    <hr />

    <h2>Child Pages:</h2>
    <ul>
    
    {% for childPage in page.childPages %}	
      <li><a href="/{{ childPage.urlPath }}">{{ childPage.title }}</a></li>
    {% endfor %}
    </ul>
  {% endif %}

</article>