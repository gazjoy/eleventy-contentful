---
title: Where We Train
layout: layouts/base.njk
permalink: /where-we-train/index.html
---

<h1>{{ title }}</h1>

{% for venue in venues %}

  <h2>{{ venue.name }}</h2>

  <div class="mapouter">
    <div class="gmap_canvas">
      <iframe 
        class="gmap_iframe" 
        frameborder="0" 
        scrolling="no" 
        marginheight="0" 
        marginwidth="0" 
        src="https://maps.google.com/maps?width=800&amp;height=500&amp;hl=en&amp;q={{venue.name}};t=&amp;z=14&amp;ie=UTF8&amp;iwloc=B&amp;output=embed">
      </iframe>
    </div>
    <style>
      .mapouter{position:relative;text-align:right;width:800px;height:500px;}
      .gmap_canvas {overflow:hidden;background:none!important;width:800px;height:500px;}
      .gmap_iframe {width:800px!important;height:500px!important;}
    </style>
  </div>

  <p>
    <a href={{venue.website}}>{{venue.website}}</a>
    <br/>
    <a href="tel:{{venue.phoneNumber}}">{{venue.phoneNumber}}</a>
  </p>

  {% if not loop.last %}
    <hr/>
  {% endif %}

{% endfor %}
