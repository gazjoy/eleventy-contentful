---
title: Where We Train
layout: layouts/base.njk
permalink: /where-we-train/index.html

---

<h1>{{ title }}</h1>
{% for venue in venues %}
  <h2>{{ venue.name }}</h2>
  <div class="relative w-full max-w-200 h-125">
    <div class="overflow-hidden w-full h-full">
      <iframe
        class="w-full h-full"
        frameborder="0"
        scrolling="no"
        marginheight="0"
        marginwidth="0"
        src="https://maps.google.com/maps?width=800&amp;height=500&amp;hl=en&amp;q={{ venue.name }};t=&amp;z=14&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"></iframe>
    </div>
  </div>
  <p>
    <a href="{{ venue.websiteUrl }}">{{ venue.websiteUrl }}</a>
    <br/>
    <a href="tel:{{ venue.phoneNumber }}">{{ venue.phoneNumber }}</a>
  </p>
  {% if not loop.last %}
    <hr/>
  {% endif %}
{% endfor %}