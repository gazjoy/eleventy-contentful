---
layout: layouts/base.njk
pagination:
  data: news
  size: 1
  alias: post
permalink: /news/{{ post.slug }}/index.html
---

<article>
  <h1>{{ post.title }}</h1>
  <p>By {{ post.author }} on {{ post.date | readableDate }}</p>
  <div>{{ post.bodyRichText | renderRichTextAsHtml(contentLinkLookups) | safe }}</div>
  <p><a href="/news/">← Back to news</a></p>
</article>