---
eleventyComputed:
  title: "{{ homepage.title }}"
layout: layouts/base.njk
permalink: /index.html
bodyClass: page-home
---

<section class="masthead masthead--full">

  <!-- Background image -->
  <div
    class="absolute inset-0 bg-cover bg-center scale-105"
    style="background-image: url('https://images.unsplash.com/photo-1669185694564-2da287319e13?fm=jpg&q=60&w=3000&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');"
  ></div>
    {# style="background-image: url(&quot;https://images.unsplash.com/photo-1653367298534-6fa20c0f8f60?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjb21wZXRpdGl2ZSUyMHN3aW1taW5nJTIwcG9vbCUyMHVuZGVyd2F0ZXJ8ZW58MXx8fHwxNzc0NDYwOTU5fDA&amp;ixlib=rb-4.1.0&amp;q=80&amp;w=1080&quot;);" #}

  

  <!-- Gradient overlay -->
  {# <div
    class="absolute inset-0 bg-gradient-to-b from-[#0d2240]/80 via-[#0d2240]/60 to-[#0d2240]/90"
  ></div> #}

  <!-- Noise effect -->
  {# <div
    class="absolute inset-0 opacity-10"
    style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255, 255, 255, 0.08) 2px, rgba(255, 255, 255, 0.08) 4px); background-size: 100% 8px;"
  ></div> #}

  <!-- Content -->
  <div class="masthead__content">

    <p class="eyebrow">Inspiring every swimmer</p>
    <h1 class="mb-6 text-white">Cannock Phoenix <br />
      <span class="text-secondary">Swimming Club</span>
    </h1>

    <!-- Description -->
    <p class="masthead__description">From first splash to podium finish. A proud Swim England affiliated, non-profit club supporting young swimmers in Staffordshire since 1980.</p>

    <!-- CTA Buttons -->
    <div
      class="flex flex-col sm:flex-row gap-4 justify-center"
    >
      <a
        class="btn inline-flex items-center justify-center gap-2 px-7 py-4 bg-secondary hover:bg-[#a81818] text-white rounded-full transition-all duration-200 shadow-xl hover:shadow-[#cc1e1e]/40 hover:-translate-y-0.5"
        href="/learn-to-swim"
      >
        Request a free trial
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-arrow-right"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <a
        class="btn inline-flex items-center justify-center gap-2 px-7 py-4 bg-white/15 hover:bg-white/25 backdrop-blur-sm text-white rounded-full border border-white/30 transition-all duration-200 hover:-translate-y-0.5"
        href="/about"
      >
        More about Phoenix
      </a>
    </div>

    <div
      class="flex flex-col sm:flex-row gap-4 justify-center mt-4"
    >
      <a href="https://www.swimming.org/poolfinder/clubs/1499/1005345/Cannock+Phoenix+Swimming+Club/" target="_blank" class="logo logo--se">
        <img src="/images/Swim_England_500x159px.gif" alt="Swim England" class="w-120" />
        Swim England Club Page
      </a>
    </div>
  </div>

  <!-- Wave -->
  <div class="wave">
    {% include "svg/wave.svg" %}
  </div>
</section>

<h1 class="text-4xl font-bold text-gray-900 mb-6">{{ title }}</h1>

{% set components = homepage.components %}
{% include "components/dynamic-components.njk" %}