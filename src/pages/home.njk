--- 
eleventyComputed:
  title: "{{ homepage.title | slug }}"
layout: layouts/base.njk
permalink: /index.html
bodyClass: page-home

---

<section
  class="masthead masthead--full">
  <!-- Background image -->
  <div
    class="absolute inset-0 bg-cover bg-center scale-105"
    style="background-image:
      url('https://images.unsplash.com/photo-1669185694564-2da287319e13?fm=jpg&q=60&w=1920&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');"></div>
  {# style="background-image: url(&quot;https://images.unsplash.com/photo-1653367298534-6fa20c0f8f60?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjb21wZXRpdGl2ZSUyMHN3aW1taW5nJTIwcG9vbCUyMHVuZGVyd2F0ZXJ8ZW58MXx8fHwxNzc0NDYwOTU5fDA&amp;ixlib=rb-4.1.0&amp;q=80&amp;w=1080&quot;);" #}
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-linear-to-b from-primary/80 via-primary/60 to-primary/90"></div>
  <!-- Shimmer effect (diagonal light sweep) -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(115deg, transparent 40%, rgba(255, 255, 255, 0.06) 50%, transparent 60%);
      background-size: 200% 100%; animation: shimmer 8s ease-in-out infinite alternate;"></div>
  <!-- Content -->
  <div class="masthead__content">
    <p class="eyebrow">Inspiring every swimmer</p>
    <h1 class="mb-6 text-white">
      Cannock Phoenix <br/>
      <span class="text-secondary">Swimming Club</span>
    </h1>
    <!-- Description -->
    <p class="masthead__description">
      From first splash to podium finish. A proud Swim England affiliated, non-profit club supporting young swimmers in
      Staffordshire since 1980.
    </p>
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        class="btn inline-flex items-center justify-center gap-2 px-7 py-4 bg-secondary hover:bg-[#a81818] text-white
          rounded-full transition-all duration-200 shadow-xl hover:shadow-secondary/40 hover:-translate-y-0.5"
        href="/learn-to-swim">
        Request a free trial
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-arrow-right shrink-0">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <a
        class="btn inline-flex items-center justify-center gap-2 px-7 py-4 bg-white/15 hover:bg-white/25 backdrop-blur-sm
          text-white rounded-full border border-white/30 transition-all duration-200 hover:-translate-y-0.5"
        href="/about">
        More about Phoenix
      </a>
    </div>
  </div>
  <!-- Wave -->
  <div class="wave">
    {% include "svg/wave.svg" %}
  </div>
</section>
{# ── About Teaser ──────────────────────────────────────────────────────── #}
<section class="bg-[#f5f8fc] py-20">
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12 items-center">
    {# Image column #}
    <div class="relative">
      <div class="rounded-2xl overflow-hidden shadow-2xl aspect-[4/3]">
        <img
          src="https://images.unsplash.com/photo-1769490315056-fd1bb6832239?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxzd2ltbWluZyUyMHBvb2wlMjB3YXRlciUyMHN1cmZhY2UlMjBibHVlfGVufDF8fHx8MTc3NDQ2MDk2Mnww&ixlib=rb-4.1.0&q=80&w=1080"
          alt="Cannock Phoenix swimming pool"
          class="w-full h-full object-cover"
          width="1080"
          height="810"
          loading="lazy"/>
      </div>
      {# Floating badge #}
      <div class="absolute -bottom-5 -right-5 bg-primary text-white rounded-2xl p-5 shadow-xl hidden sm:block">
        <p class="text-3xl font-black text-secondary font-montserrat">45</p>
        <p class="text-xs text-white/70 uppercase tracking-wider mt-0.5">Years Strong</p>
      </div>
    </div>
    {# Text column #}
    <div>
      <span class="text-secondary text-sm uppercase tracking-widest font-semibold font-montserrat">
        About the Club
      </span>
      <h2 class="mt-2 text-primary font-montserrat font-extrabold leading-tight">
        Born from community,<br>built on ambition
        </h2>
        <p class="mt-4 text-primary/70 leading-relaxed">
          Cannock Phoenix Swimming Club has been nurturing talent in the Staffordshire swimming community since 1980. What started
          as a small local group has grown into a thriving non-profit club of over 50 members, supporting swimmers from their very
          first lesson right through to competitive racing.
        </p>
        <p class="mt-3 text-primary/70 leading-relaxed">
          We believe every child deserves the confidence and joy that comes from being a competent swimmer — and for those with
          the fire to compete, we provide the coaching and support to help them achieve their potential.
        </p>
        <a href="/about/" class="mt-6 inline-flex items-center gap-2 text-secondary font-semibold hover:gap-3 transition-all">
          Learn more about us
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
  {# ── Programmes ────────────────────────────────────────────────────────── #}
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-secondary text-sm uppercase tracking-widest font-semibold font-montserrat">
          Our Programmes
        </span>
        <h2 class="mt-2 text-primary font-montserrat font-extrabold">
          A programme for every swimmer
        </h2>
      </div>
      <div
        class="grid md:grid-cols-2 gap-8">
        {# Learn to Swim card #}
        <div class="group rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1
            bg-white border border-gray-100">
          <div class="relative h-60 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1761589871820-b9cfbfb5d853?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjaGlsZCUyMGxlYXJuaW5nJTIwdG8lMjBzd2ltJTIwcG9vbHxlbnwxfHx8fDE3NzQ0NjA5NTl8MA&ixlib=rb-4.1.0&q=80&w=1080"
              alt="Child learning to swim"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width="1080"
              height="720"
              loading="lazy"/>
            <div class="absolute inset-0 bg-linear-to-t from-primary/70 to-transparent"></div>
            <div class="absolute bottom-4 left-4">
              <span class="px-3 py-1 bg-secondary text-white text-xs rounded-full uppercase tracking-wider font-montserrat font-bold">
                Beginners Welcome
              </span>
            </div>
          </div>
          <div class="p-7">
            <h3 class="text-primary font-montserrat font-extrabold text-xl">Learn to Swim</h3>
            <p class="mt-2 text-primary/65 leading-relaxed text-sm">
              From water confidence for young beginners through to club-ready swimming — our structured programme gives children the
              skills, safety and love of the water to thrive.
            </p>
            <a
              href="/learn-to-swim/"
              class="mt-5 inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:bg-secondary text-white text-sm font-semibold
                rounded-full transition-colors">
              Find out more
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
        {# Competitive Squad card #}
        <div class="group rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1
            bg-white border border-gray-100">
          <div class="relative h-60 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1621354559364-b7404d160bd1?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxzd2ltJTIwdGVhbSUyMHRyYWluaW5nJTIwY29hY2glMjBwb29sc2lkZXxlbnwxfHx8fDE3NzQ0NjA5NjN8MA&ixlib=rb-4.1.0&q=80&w=1080"
              alt="Competitive swim squad training"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width="1080"
              height="720"
              loading="lazy"/>
            <div class="absolute inset-0 bg-linear-to-t from-primary/70 to-transparent"></div>
            <div class="absolute bottom-4 left-4">
              <span class="px-3 py-1 bg-secondary text-white text-xs rounded-full uppercase tracking-wider font-montserrat font-bold">
                Competitive
              </span>
            </div>
          </div>
          <div class="p-7">
            <h3 class="text-primary font-montserrat font-extrabold text-xl">Competitive Squad</h3>
            <p class="mt-2 text-primary/65 leading-relaxed text-sm">
              For swimmers ready to race. Our competitive squad trains regularly with experienced coaches and competes at regional
              galas, helping young athletes make genuine progress.
            </p>
            <a
              href="/competitive-squads/"
              class="mt-5 inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:bg-secondary text-white text-sm font-semibold
                rounded-full transition-colors">
              Find out more
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  {#
                              Next Event section.
                              This section will not render unless there is at least one upcoming event in Contentful.
                            #}
  {% set nextEvent = events.upcoming[0] if events.upcoming | length > 0 %}
  {% if nextEvent %}
    <section
      class="bg-primary py-20 relative overflow-hidden">
      {# TODO Phase D: move radial-gradient texture to a CSS class #}
      <div
        class="absolute inset-0 opacity-5"
        style="background-image: radial-gradient(circle at 20% 50%, #cc1e1e 0%, transparent 60%), radial-gradient(circle at 80%
          50%, #1a6fa3 0%, transparent 60%);"
        aria-hidden="true"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-10">
          <span class="text-secondary text-sm uppercase tracking-widest font-semibold font-montserrat">
            Next Event
          </span>
          <h2 class="mt-2 text-white font-montserrat font-extrabold">Coming Up</h2>
        </div>
        <div class="max-w-3xl mx-auto bg-white/5 backdrop-blur border border-white/10 rounded-3xl p-8 md:p-10">
          <div
            class="flex flex-row items-start gap-6">
            {# Date block #}
            <div class="shrink-0 bg-secondary rounded-2xl p-5 text-center min-w-20">
              <p class="text-white/80 text-xs uppercase tracking-widest">{{ nextEvent.startDate | luxonFormat("LLL") }}</p>
              <p class="text-white font-black leading-none font-montserrat text-4xl">{{ nextEvent.startDate | luxonFormat("d") }}</p>
              <p class="text-white/80 text-xs mt-1">{{ nextEvent.startDate | luxonFormat("yyyy") }}</p>
            </div>
            {# Event details #}
            <div class="flex-1">
              <h3 class="text-white font-montserrat font-extrabold text-xl">{{ nextEvent.title }}</h3>
              <div class="mt-3 flex flex-wrap gap-4 text-white/60 text-sm">
                {% if nextEvent.venue.name %}
                  <span class="flex items-center gap-1.5">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-secondary shrink-0"
                      aria-hidden="true">
                      <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                    {{ nextEvent.venue.name }}
                  </span>
                {% endif %}
                {% if nextEvent.startTime %}
                  <span class="flex items-center gap-1.5">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-secondary shrink-0"
                      aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {{ nextEvent.startTime | readableTime }}
                  </span>
                {% endif %}
                <span class="flex items-center gap-1.5">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-secondary shrink-0"
                    aria-hidden="true">
                    <path d="M8 2v4"/>
                    <path d="M16 2v4"/>
                    <rect width="18" height="18" x="3" y="4" rx="2"/>
                    <path d="M3 10h18"/>
                  </svg>
                  {{ nextEvent.startDate | readableDate }}
                </span>
              </div>
              {% if nextEvent.descriptionRichText %}
                <div class="mt-4 text-white/70 leading-relaxed text-sm">
                  {{ nextEvent.descriptionRichText | renderRichTextAsHtml | safe }}
                </div>
              {% endif %}
              <div class="mt-6 flex flex-wrap gap-3">
                {% if nextEvent.websiteUrl %}
                  <a href="{{ nextEvent.websiteUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-secondary hover:bg-[#a81818] text-white text-sm font-semibold rounded-full transition-colors">
                    Event Info
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true">
                      <path d="M15 3h6v6"/>
                      <path d="M10 14 21 3"/>
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    </svg>
                  </a>
                {% endif %}
                <a
                  href="/events/"
                  class="inline-flex items-center gap-2 px-5 py-2.5 border border-white/30 hover:bg-white/10 text-white text-sm
                    font-semibold rounded-full transition-colors">
                  Full Calendar
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true">
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  {% endif %}
  {% set components = homepage.components %}
  {% include "components/dynamic-components.njk" %}