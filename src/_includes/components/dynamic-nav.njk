{#
	Renders a dynamic navigation, including all the pages defined in the CMS.
	Uses the global "pages" data 
#}

{% macro renderNavLink(url, title, currentUrl) %}
	{% set dynamicClass = "text-white/85" %}
	{% if "🔒" in title %}
		{% set dynamicClass = "text-emerald-400 font-semibold" %}
	{% endif %}
	{% if url == currentUrl %}
		<strong class="text-white font-medium">{{ title }}</strong>
	{% else %}
		<a href="{{ url }}" class="px-3 py-2 text-sm transition-colors duration-150 
		rounded-md hover:text-white hover:bg-white/10 {{ dynamicClass }}">{{ title }}</a>
	{% endif %}
{% endmacro %}

<nav class="site-nav">
	<ul class="flex flex-col md:flex-row gap-4 md:gap-8">
		<li>{{ renderNavLink("/news/", "News", page.url) }}</li>
		<li>{{ renderNavLink("/events/", "Events", page.url) }}</li>
		<li>{{ renderNavLink("/competitive-squads/", "Competitive Squads", page.url) }}</li>
		<li>{{ renderNavLink("/coaching-staff/", "Coaching Staff", page.url) }}</li>
		<li>{{ renderNavLink("/where-we-train/", "Where We Train", page.url) }}</li>
	
		{% for level1Page in pages.hierarchy %}
		<li>
			{{ renderNavLink("/" + level1Page.urlPath + "/", level1Page.title, page.url) }}

			{% if level1Page.childPages.length > 0 %}
			<ul>
				{% for level2Page in level1Page.childPages %}
				<li>
					{{ renderNavLink("/" + level2Page.urlPath + "/", level2Page.title, page.url) }}
					{% if level2Page.childPages.length > 0 %}
					<ul>
						{% for level3Page in level2Page.childPages %}
						<li>
							{{ renderNavLink("/" + level3Page.urlPath + "/", level3Page.title, page.url) }}
						</li>
						{% endfor %}
					</ul>
					{% endif %}
				</li>
				{% endfor %}
			</ul>
			{% endif %}
		</li>
		{% endfor %}

		<li>{{ renderNavLink("/contact-static/", "Static contact", page.url) }}</li>
		<li>{{ renderNavLink("/payments/", "🔒 Pay fees", page.url) }}</li>
	</ul>
</nav>
