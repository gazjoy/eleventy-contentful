{#
  Page Hero Component

  Reusable sub-page hero banner with section identity, title, subtitle, and wave divider.

  Parameters (set before including):
    heroSectionLabel  — e.g. "Our Club", "Learn", "Compete" (required)
    heroAccentColor   — hex color e.g. "#db2777" (required)
    heroSvgPaths      — array of SVG path `d` attribute strings for the section icon (required)
    heroTitle         — page title (required)
    heroSubtitle      — optional subtitle text
    heroImage         — optional background image URL (Unsplash or upload)
#}
<section
  class="relative pt-28 pb-14 bg-primary text-white overflow-hidden">
  <!-- Background image (optional, 20% opacity over dark blue) -->
  {% if heroImage %}
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('{{ heroImage }}');"></div>
  {% else %}
    <!-- Fallback texture when no image -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%);
        background-size: 12px 12px;"></div>
  {% endif %}
  <!-- Content -->
  <div
    class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section label -->
    <span class="text-white/50 text-xs uppercase tracking-widest font-montserrat font-bold block mb-4">
      {{ heroSectionLabel }}
    </span>
    <!-- Icon + Title inline -->
    <div class="flex items-center gap-4">
      <div
        class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0"
        style="background-color: {{ heroAccentColor }}20;">
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="color: {{ heroAccentColor }};"
          aria-hidden="true">
          {% for path in heroSvgPaths %}
            <path d="{{ path }}"/>
          {% endfor %}
        </svg>
      </div>
      <h1 class="text-white mb-0" style="font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.1;">
        {{ heroTitle }}
      </h1>
    </div>
    <!-- Subtitle (optional) -->
    {% if heroSubtitle %}
      <p class="mt-3 text-white/60 max-w-xl leading-relaxed font-inter">
        {{ heroSubtitle }}
      </p>
    {% endif %}
  </div>
  <!-- Wave divider -->
  <div class="wave">
    {% include "svg/wave-small.svg" %}
  </div>
</section>