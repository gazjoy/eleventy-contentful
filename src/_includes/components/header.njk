<header class="site-header bg-primary text-white">
  <div
    class="max-w-7xl mx-auto px-4 py-3">
    <!-- Top Row: Logo + Hamburger/Actions -->
    <div
      class="flex items-center justify-between">
      <!-- Logo -->
      <div class="shrink-0">
        <a href="/" class="logo flex items-center gap-2 md:gap-3 hover:opacity-80">
          <img src="/images/CPSC-Logo.png" alt="Cannock Phoenix"/>
          <div class="hidden">
            <div class="text-xs font-semibold tracking-wide">
              CANNOCK PHOENIX
            </div>
            <div class="text-xs md:text-sm font-bold">Swimming Club</div>
          </div>
        </a>
      </div>
      <!-- Center: Desktop Nav (lg+) | Empty on mobile -->
      <div class="hidden lg:flex items-center justify-between gap-8 ml-8">
        {% include "components/dynamic-nav.njk" %}
      </div>
      <!-- Right: Login + Menu Toggle -->
      <div
        class="flex items-center gap-4">
        <!-- Login to Swim Manager (all screen sizes) -->
        <a href="https://phoenixyth.swimmanager.co.uk/login" class="btn btn--secondary btn--icon">
          <div class="icon">
            <img src="https://swimmanager.co.uk/wp-content/uploads/2025/10/Logo-Only180px.png" alt="Swim Manager" class="w-5 h-5">
          </div>
          <span>Login to Swim Manager</span>
        </a>
        <!-- Mobile: Menu label + Hamburger/X -->
        <button id="menu-toggle" class="lg:hidden flex items-center gap-2 text-white">
          <span class="text-sm font-medium">Menu</span>
          <!-- Hamburger icon -->
          <svg id="icon-hamburger" class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <!-- Close icon -->
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewbox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile Menu: Nav (stacked below) -->
    <nav id="nav-menu" class="hidden lg:hidden flex-col pb-4 mt-4">
      <div class="flex flex-col gap-4 pt-4 border-t border-white/20">
        {% include "components/dynamic-nav.njk" %}
      </div>
    </nav>
  </div>
</header>