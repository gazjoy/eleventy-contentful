{#
    Expects the context to contain an event object called "event"
#}

<div style="width: 120px;
height:140px; 
margin: 10px; 
padding:0; 
background-color: #b0b0b0;
border:10px solid #b0b0b0;
border-radius:20px;
text-align: center;">
    <span>{{ event.startDate.toFormat("LLLL").toUpperCase() }}</span>
    <br/>
    <span style="font-size:60px;font-weight:bold;">{{ event.startDate.day }}</span>
    <br/>
    <span>{{ event.startDate.year }}</span>
</div>