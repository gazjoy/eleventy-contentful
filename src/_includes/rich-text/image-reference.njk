{# 
    Expects the context to include:
    - image: the referenced image (see src/lib/contentful/assetMapper.js)
    - type: the type of reference ("asset-hyperlink" | "embedded-asset-block")
    - linkText: only relevant for "asset-hyperlink" type
#}

{# render simple link #}
{% if type == "asset-hyperlink" %}
  <a href="{{ image.url }}" target="_blank" rel="noopener noreferrer">{{
    linkText or image.title
  }}</a>

  {# render as image with caption #}
{% elif type == "embedded-asset-block" %}
  <p class="w-fit text-center">
    <img
      src="{{ image.url }}"
      alt="{{ image.description or '' }}"
      class="max-w-full h-auto"
    />
    <br />
    <small>{{ image.title }}</small>
  </p>
{% else %}
  <!-- Unhandled image reference type "{{ type }}" -->
{% endif %}
