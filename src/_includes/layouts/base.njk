<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    {% if not config.allowRobots %}
      <meta name="robots" content="noindex, nofollow"/>
    {% endif %}
    <link rel="icon" type="image/png" href="/favicon.png"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="/css/tailwind.css"/>
    <link rel="stylesheet" href="/css/components/navbar.css"/>
  </head>
  <body class="{{ bodyClass | default('') }}">
    <header class="site-header fixed top-0 left-0 right-0 z-50 h-16 lg:h-[60px] transition-colors duration-300 text-white bg-primary">
      <div
        class="max-w-7xl mx-auto px-4 h-full flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="shrink-0 hover:opacity-80 transition-opacity">
          <img src="/images/CPSC-Logo.png" alt="Cannock Phoenix Swimming Club" class="w-10 h-10 lg:w-12 lg:h-12"/>
        </a>
        <!-- Center: Desktop Nav (lg+) -->
        <div class="hidden lg:flex items-center justify-center gap-8 flex-1">
          {% include "components/navbar-menu.njk" %}
        </div>
        <!-- Right: CTA + Menu Toggle -->
        <div
          class="flex items-center gap-4">
          <!-- Request a Trial CTA (desktop only) -->
          <a
            href="/join/"
            class="hidden lg:inline-flex items-center px-5 py-2 bg-secondary hover:bg-red-900 text-white text-sm font-semibold
              rounded-full transition-colors">
            Request a Trial
          </a>
          <!-- Mobile: Menu label + Hamburger/X -->
          <button
            id="menu-toggle"
            class="lg:hidden flex items-center gap-2 text-white p-2 hover:bg-white/10 rounded-lg transition-colors"
            aria-label="Toggle navigation menu"
            aria-expanded="false">
            <span class="text-sm font-medium">Menu</span>
            <!-- Hamburger icon -->
            <svg
              id="icon-hamburger"
              class="w-5 h-5"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <path d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <!-- Close icon (hidden by default) -->
            <svg
              id="icon-close"
              class="w-5 h-5 hidden"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile Menu: Nav (stacked below) -->
      <nav id="nav-menu" class="hidden lg:hidden flex-col pb-4 lg:mt-4 bg-primary max-h-[85vh] overflow-y-auto px-4">
        <div class="flex flex-col gap-0.5 pt-4 border-t border-white/10">
          {% include "components/navbar-menu.njk" %}
        </div>
        <!-- Mobile CTA Button -->
        <div class="px-4 pt-3 pb-2">
          <a
            href="/join/"
            class="w-full block text-center py-3 bg-secondary hover:bg-red-900 text-white text-sm font-semibold rounded-full
              transition-colors">
            Request a Trial
          </a>
        </div>
      </nav>
    </div>
  </body>
</html></header><main class="pt-16 lg:pt-15">
{{ content | safe }}</main><footer class="site-footer">
<div class="site-footer__inner">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <div class="lg:col-span-1">
        <img src="/images/CPSC-Logo.png" alt="Cannock Phoenix Swimming Club" class="w-10 h-10" />
        <p class="mt-4 text-white/60 text-sm leading-relaxed" style="font-family: Inter, sans-serif;">
          A non-profit swimming club based in Cannock, Staffordshire. Established 1980. Supporting local swimmers of all abilities
          on their journey in the water.
        </p>
        <div class="flex gap-3 mt-5">
          <a
            href="#"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-secondary flex items-center justify-center transition-colors"
            aria-label="Facebook">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-facebook">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a
            href="#"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-secondary flex items-center justify-center transition-colors"
            aria-label="Twitter">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-twitter">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8
                1.1 0 3-1.2 3-1.2z"></path>
            </svg>
          </a>
          <a
            href="#"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-secondary flex items-center justify-center transition-colors"
            aria-label="Instagram">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-instagram">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
        </div>
      </div>
      <div>
        <h3>Club</h3>
        <ul class="space-y-2 text-sm text-white/65" style="font-family: Inter, sans-serif;">
          <li>
            <a class="hover:text-white transition-colors" href="/about">About Us</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/about/committee">Club Committee</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/competitive-squad">Competitive Squad</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/events">Events &amp; Galas</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/news">News</a>
          </li>
        </ul>
      </div>
      <div>
        <h3>Get Involved</h3>
        <ul class="space-y-2 text-sm text-white/65" style="font-family: Inter, sans-serif;">
          <li>
            <a class="hover:text-white transition-colors" href="/learn-to-swim">Learn to Swim</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/learn-to-swim">Request a Trial</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/volunteering">Volunteering</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/volunteering">Fundraising</a>
          </li>
        </ul>
      </div>
      <div>
        <h3>Contact</h3>
        <ul class="space-y-3 text-sm text-white/65" style="font-family: Inter, sans-serif;">
          <li class="flex gap-2 items-start">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-map-pin mt-0.5 text-secondary shrink-0">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Cannock Chase Leisure Centre,<br>Auctioneers Way,
                                  Cannock, WS11 1AB</span>
          </li>
          <li class="flex gap-2 items-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewbox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-mail text-secondary shrink-0">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <a href="m&#97;il&#116;&#111;&#58;in%66&#111;&#64;c&#37;&#54;1&#110;&#110;&#111;c&#37;&#54;Bs&#119;&#105;%6&#68;m&#105;ng&#99;l&#117;b&#46;o&#37;&#55;2%6&#55;">
            i&#110;fo&#64;ca&#110;nock&#115;wimm&#105;ng&#99;l&#117;b&#46;or&#103;</a>
          </li>
        </ul>
      </div>
    </div>
    <!-- Swim England Affiliation -->
    <div
      class="border-t border-white/10 py-10 flex flex-col sm:flex-row items-center gap-8 sm:gap-12">
      <!-- Swim England Logo -->
      <div class="shrink-0 bg-white rounded-2xl px-7 py-4">
        <img src="/images/Swim_England_500x159px.gif" alt="Swim England" class="h-10 w-auto"/>
      </div>
      <!-- Tagline -->
      <p class="text-white/55 text-sm leading-relaxed text-center sm:text-left" style="font-family: Inter, sans-serif;">
        From first splash to podium finish. A proud
        <a
          href="https://www.swimming.org"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/80 hover:text-white transition-colors underline underline-offset-2">Swim England</a>
        affiliated, non-profit club supporting young swimmers in Staffordshire since 1980.
      </p>
    </div>
    <div class="site-footer__footer border-t border-white/10 pt-6">
      <p>
        &copy; 2026
        <a href="/" class="link">Cannock Phoenix Swimming Club</a>. Registered Non-Profit. Est.
                        1980. |
        <a href="/styles/" class="link">Styles</a>
      </p>
      <div class="flex items-center gap-4">
        <a class="link link--pay flex items-center gap-1.5" href="/payments">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="11"
            height="11"
            viewbox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-lock">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          Pay Fees Securely
        </a>
      </div>
    </div>
  </div>
</div></footer><script src="/js/navbar.js"></script></body></html>