<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    {% if not config.allowRobots %}
        <meta name="robots" content="noindex, nofollow" />
    {% endif %}

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    {# <link rel="stylesheet" href="/assets/css/style.css"> #}
</head>
<body>
    <header style="background-color:aliceblue;border-bottom:2px solid black;">
        {% include "components/dynamic-nav.njk" %}
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer style="background-color:aliceblue;border-top:2px solid black;">
        <p>&copy; My Website. All rights reserved.</p>
    </footer>
</body>
</html>