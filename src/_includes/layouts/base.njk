<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    {% if not config.allowRobots %}
        <meta name="robots" content="noindex, nofollow" />
    {% endif %}

    <link rel="icon" type="image/png" href="/favicon.png"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link rel="stylesheet" href="/css/tailwind.css" />

    <style>
a[href]:not(:where(
  /* exclude hash only links */
  [href^="#"],
  /* exclude javascript only links */
  [href^="javascript:" i],  
  /* exclude relative but not double slash only links */
  [href^="/"]:not([href^="//"]),
)):after {
  content: ' ↗️';
}
    </style>
</head>
<body>
    <header class="site-header bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 py-3">
    <!-- Top Row: Logo + Hamburger/Actions -->
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <div class="shrink-0">
        <a href="/" class="logo flex items-center gap-2 md:gap-3 hover:opacity-80">
          <img src="/images/CPSC-Logo.png" alt="Cannock Phoenix" class="w-10 h-10 md:w-12 md:h-12" />
          <div class="">
            <div class="text-xs font-semibold tracking-wide">CANNOCK PHOENIX</div>
            <div class="text-xs md:text-sm font-bold">Swimming Club</div>
          </div>
        </a>
      </div>
      
      <!-- Desktop: Nav + Request Trial | Mobile: Hamburger -->
      <div class="hidden md:flex flex-1 items-center justify-between gap-8 ml-8">
        {% include "components/dynamic-nav.njk" %}
        <a href="#trial" class="bg-secondary text-white px-6 py-2 rounded-full font-semibold hover:bg-opacity-90 transition shrink-0">
          Request a Trial
        </a>
      </div>
      
      <!-- Mobile: Menu label + Hamburger/X -->
      <button id="menu-toggle" class="md:hidden flex items-center gap-2 text-white">
        <span class="text-sm font-medium">Menu</span>
        <!-- Hamburger icon -->
        <svg id="icon-hamburger" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon -->
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- Mobile Menu: Nav + Request Trial (stacked below) -->
    <nav id="nav-menu" class="hidden md:hidden flex-col pb-4 mt-4">
      <div class="flex flex-col gap-4 pt-4 border-t border-white/20">
        {% include "components/dynamic-nav.njk" %}
      </div>
      <div class="pt-4 mt-2 border-t border-white/20">
        <a href="#trial" class="block bg-secondary text-white px-4 py-2 rounded-full font-semibold hover:bg-opacity-90 transition text-center">
          Request a Trial
        </a>
      </div>
    </nav>
  </div>
</header>

    <main>
        {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
    <div class="lg:col-span-1">
      <div class="flex items-center gap-2.5 select-none">
        <svg width="48" height="48" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Cannock Phoenix Swimming Club crest">
          <circle cx="32" cy="32" r="31" fill="#0d2240" stroke="#ffffff" stroke-width="2"></circle>
          <path d="M8 44 Q16 40 24 44 Q32 48 40 44 Q48 40 56 44 L56 54 Q48 58 40 54 Q32 50 24 54 Q16 58 8 54 Z" fill="#cc1e1e" opacity="0.85"></path>
          <path d="M32 8 C28 14 22 16 24 22 C22 20 20 22 22 26 C20 24 18 27 21 30 C24 33 28 31 30 35 C31 37 32 40 32 40 C32 40 33 37 34 35 C36 31 40 33 43 30 C46 27 44 24 42 26 C44 22 42 20 40 22 C42 16 36 14 32 8Z" fill="#cc1e1e"></path>
          <path d="M32 14 C30 18 27 19 28 23 C27 21 26 22.5 27.5 25 C26 24 25 26 27 28 C29 30 31 29 32 32 C33 29 35 30 37 28 C39 26 38 24 36.5 25 C38 22.5 37 21 36 23 C37 19 34 18 32 14Z" fill="#ffffff" opacity="0.3"></path>
          <text x="32" y="49" text-anchor="middle" fill="#ffffff" font-size="7" font-family="Montserrat, sans-serif" font-weight="700" letter-spacing="1">CPSC</text>
        </svg>
        <div class="flex flex-col leading-none">
          <span class="text-xs tracking-widest uppercase text-white/80" style="font-family: Montserrat, sans-serif; font-size: 0.6rem;">Cannock Phoenix</span>
          <span class="tracking-wide text-white" style="font-family: Montserrat, sans-serif; font-size: 0.85rem; font-weight: 800;">Swimming Club</span>
        </div>
      </div>
      <p class="mt-4 text-white/60 text-sm leading-relaxed" style="font-family: Inter, sans-serif;">A non-profit swimming club based in Cannock, Staffordshire. Established 1980. Supporting local swimmers of all abilities on their journey in the water.</p>
      <div class="flex gap-3 mt-5">
        <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-secondary flex items-center justify-center transition-colors" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
        <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-secondary flex items-center justify-center transition-colors" aria-label="Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-twitter">
            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
          </svg>
        </a>
        <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-secondary flex items-center justify-center transition-colors" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram">
