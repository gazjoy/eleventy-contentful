  },
  "homepage": "https://github.com/gazjoy/eleventy-contentful#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@contentful/rich-text-html-renderer": "^17.1.6",
    "@tailwindcss/cli": "^4.2.4",
    "contentful": "^11.12.0",
    "dotenv": "^17.4.2",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.4"
