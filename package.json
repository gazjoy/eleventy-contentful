  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@contentful/rich-text-html-renderer": "^17.1.6",
    "contentful": "^11.12.0",
    "dotenv": "^17.4.2",
    "luxon": "^3.7.2",
    "sass": "^1.99.0"
  },
