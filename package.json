  "main": "index.js",
  "scripts": {
    "clean": "rimraf _site",
    "dev:css": "npx tailwindcss -i ./src/css/tailwind.css -o ./_site/css/tailwind.css --watch",
    "build:css": "npx tailwindcss -i ./src/css/tailwind.css -o ./_site/css/tailwind.css --build",
    "dev:eleventy": "eleventy --serve",
    "build:eleventy": "eleventy",
    "start": "npm run clean && run-p dev:*",
    "build": "run-p build:*",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
