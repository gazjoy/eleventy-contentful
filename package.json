{
  "name": "eleventy-contentful",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf _site",
    "watch:sass": "sass --watch src/static/sass:_site/css",
    "build:sass": "sass src/static/sass:_site/css",
    "watch:eleventy": "eleventy --serve",
    "build:eleventy": "eleventy",
    "start": "npm run clean && npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:*",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
